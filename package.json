{
  "name": "@thenkei/prisma-soft-delete-extension",
  "version": "1.0.2",
  "description": "Soft-delete (paranoid) support for Prisma v7+ via client extensions",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "ci": "npm run typecheck && npm test -- --runInBand && npm run typecheck:usage && npm run build",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "typecheck": "tsc --noEmit",
    "typecheck:usage": "tsc -p tsconfig.type-tests.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@prisma/client": ">=7.0.0",
    "prisma": ">=7.0.0"
  },
  "devDependencies": {
    "@prisma/client": "7.5.0",
    "@prisma/adapter-better-sqlite3": "7.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "better-sqlite3": "12.8.0",
    "jest": "^29.0.0",
    "prisma": "7.5.0",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
