generator client_js {
  provider        = "prisma-client-js"
  output          = "./generated/prisma-client-js"
}

generator client {
  provider               = "prisma-client"
  output                 = "./generated/prisma-client"
  moduleFormat           = "cjs"
  generatedFileExtension = "cts"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  deletedAt DateTime?
}

model Tag {
  id   Int    @id @default(autoincrement())
  name String
}
