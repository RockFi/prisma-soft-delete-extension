generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  deletedAt DateTime?
}

model Tag {
  id   Int    @id @default(autoincrement())
  name String
}
