generator client_js {
  provider        = "prisma-client-js"
  output          = "./generated/prisma-client-js"
}

generator client {
  provider               = "prisma-client"
  output                 = "./generated/prisma-client"
  moduleFormat           = "cjs"
  generatedFileExtension = "cts"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  deletedAt DateTime?
  profileId Int?
  profile   Profile?  @relation(fields: [profileId], references: [id])
  posts     Post[]
  comments  Comment[]
}

model Profile {
  id        Int       @id @default(autoincrement())
  bio       String?
  deletedAt DateTime?
  users     User[]
}

model Post {
  id        Int       @id @default(autoincrement())
  title     String
  deletedAt DateTime?
  authorId  Int?
  author    User?     @relation(fields: [authorId], references: [id])
  comments  Comment[]
  tags      Tag[]
}

model Comment {
  id          Int        @id @default(autoincrement())
  content     String
  deletedAt   DateTime?
  authorId    Int?
  author      User?      @relation(fields: [authorId], references: [id])
  postId      Int?
  post        Post?      @relation(fields: [postId], references: [id])
  repliedToId Int?
  repliedTo   Comment?   @relation("CommentReplies", fields: [repliedToId], references: [id])
  replies     Comment[]  @relation("CommentReplies")
}

model Tag {
  id    Int    @id @default(autoincrement())
  name  String
  posts Post[]
}

model Membership {
  id          Int       @id @default(autoincrement())
  workspaceId Int
  externalId  String
  name        String
  deletedAt   DateTime?

  @@unique([workspaceId, externalId])
}
